{
  "name": "comptext-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "CompText — Domain-Specific Language for Clinical AI Preprocessing",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "dev": "npm run dev -w packages/visualizer",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "benchmark": "tsx scripts/benchmark.ts",
    "lint": "eslint packages/*/src",
    "termux:run": "node packages/cli/dist/index.js run",
    "termux:serve": "node packages/cli/dist/index.js serve",
    "termux:benchmark": "node packages/cli/dist/index.js benchmark",
    "termux:mcp": "node packages/mcp-server/dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Alex Köllnberger",
  "license": "MIT"
}
